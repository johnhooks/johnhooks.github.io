---
import ElsewhereLayout from "../shared/ElsewhereLayout.astro";
import ElsewherePageShell from "../shared/ElsewherePageShell.astro";
import "../shared/elsewhere.css";
---

<ElsewhereLayout
  title="Elsewhere | johnhooks.io"
  description="The experimental layer beneath johnhooks.io."
  canonicalPath="/elsewhere"
>
  <ElsewherePageShell
    class="elsewhere-index"
    labelledBy="elsewhere-title"
    breadcrumb={[{ label: "johnhooks.io", href: "/" }, { label: "elsewhere" }]}
  >
    <div class="elsewhere-index__inner">
      <h1 id="elsewhere-title">elsewhere</h1>
      <p>small experiments for getting lost between pages.</p>
      <ul>
        <li><a href="/elsewhere/quotes">quote wire</a></li>
      </ul>
    </div>
  </ElsewherePageShell>
</ElsewhereLayout>
