---
import ElsewhereLayout from "../shared/ElsewhereLayout.astro";
import ElsewherePageShell from "../shared/ElsewherePageShell.astro";
import "../shared/elsewhere.css";
import "./quotes.css";

type Props = {
  entryHref: string;
};

const { entryHref } = Astro.props;
---

<ElsewhereLayout
  title="Elsewhere quotes | johnhooks.io"
  description="A procedural journey through programming quotes."
  canonicalPath="/elsewhere/quotes"
>
  <ElsewherePageShell
    class="elsewhere-index"
    labelledBy="elsewhere-index-title"
    breadcrumb={[
      { label: "johnhooks.io", href: "/" },
      { label: "elsewhere", href: "/elsewhere" },
      { label: "quote wire" },
    ]}
  >
    <div class="elsewhere-index__inner">
      <h1 id="elsewhere-index-title">quote wire</h1>
      <p>two links continue. the URL keeps the seed.</p>
      <ul>
        <li><a href={entryHref} rel="nofollow">start the wire</a></li>
        <li><a href="/elsewhere/quotes/archive">index</a></li>
      </ul>
    </div>
  </ElsewherePageShell>
</ElsewhereLayout>
