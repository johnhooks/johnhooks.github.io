---
import { getProjects } from "../../lib/astro/content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { metadata: data, Content } = project;
let image;

if (data.imageFilename) {
  const imageAlt = data.cardAlt ?? data.imageAlt;

  if (!imageAlt) {
    throw new Error(
      `Image asset for project ${project.slug} requires alt text.`,
    );
  }

  image = {
    filename: data.imageFilename,
    alt: imageAlt,
  };
}
---

<ArticleLayout
  title={data.title}
  seoTitle={data.seoTitle}
  subtitle={data.abstract}
  canonicalPath={`/projects/${project.slug}`}
  cardFilename={data.cardFilename}
  cardAlt={data.cardAlt}
  image={image}
  sourceUrl={data.sourceUrl}
  sourceLabel={data.sourceLabel}
>
  <Content />
</ArticleLayout>
