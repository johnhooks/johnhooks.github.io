---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getListedProjects } from "../../lib/astro/content";

export const prerender = true;

const projects = getListedProjects();
---

<SiteLayout
  title="Projects / johnhooks.io"
  description="Projects by John Hooks."
  canonicalPath="/projects"
  breadcrumb={[{ label: "johnhooks.io", href: "/" }, { label: "projects" }]}
>
  <main class="site-shell page">
    <header class="page-header">
      <h1 class="page-header__title">projects</h1>
      <p class="page-header__subtitle">
        selected web projects and experiments.
      </p>
    </header>

    <ol class="content-list content-list--archive">
      {
        projects.map((project) => (
          <li class="content-list__item">
            <h2 class="content-list__title">
              <a href={`/projects/${project.slug}`}>{project.metadata.title}</a>
            </h2>
            <p class="content-list__summary">{project.metadata.abstract}</p>
          </li>
        ))
      }
    </ol>
  </main>
</SiteLayout>
