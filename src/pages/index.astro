---
import Image from "../components/Image.astro";
import { getPosts, getProjects } from "../lib/astro/content";
import SiteLayout from "../layouts/SiteLayout.astro";

export const prerender = true;

const posts = getPosts();
const projects = getProjects();
---

<SiteLayout title="johnhooks.io" canonicalPath="/">
  <main
    class="mx-auto max-w-[var(--measure)] px-[var(--gutter)] pb-16 sm:px-[var(--gutter-wide)]"
  >
    <Image
      filename="computer_512.png"
      alt="Hand drawn crazy-eyed computer looking at me"
      darkBackground
    />

    <header class="mt-2 sm:mt-4">
      <h1
        class="text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl"
      >
        johnhooks.io
      </h1>
      <p class="mt-4 text-base leading-7 text-[var(--color-muted)] sm:text-lg">
        just a guy learning web dev
      </p>

      <p class="mt-4 text-sm">
        <a
          class="text-[var(--color-link)] hover:underline hover:underline-offset-4"
          href="https://twitter.com/_johnhooks">Twitter</a
        >
        <span class="mx-2 text-[var(--color-muted)]">/</span>
        <a
          class="text-[var(--color-link)] hover:underline hover:underline-offset-4"
          href="https://github.com/johnhooks">GitHub</a
        >
      </p>
    </header>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-[var(--color-text)]">Posts</h2>

      <ol class="mt-5 space-y-6">
        {
          posts.map((post) => (
            <li>
              <h3 class="text-lg font-semibold">
                <a
                  class="text-[var(--color-link)] hover:underline hover:underline-offset-4"
                  href={`/posts/${post.slug}`}
                >
                  {post.metadata.title}
                </a>
              </h3>
              <p class="mt-1 text-base leading-7 text-[var(--color-muted)]">
                {post.metadata.abstract}
              </p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-[var(--color-text)]">Projects</h2>

      <ol class="mt-5 space-y-6">
        {
          projects.map((project) => (
            <li>
              <h3 class="text-lg font-semibold">
                <a
                  class="text-[var(--color-link)] hover:underline hover:underline-offset-4"
                  href={`/projects/${project.slug}`}
                >
                  {project.metadata.title}
                </a>
              </h3>
              <p class="mt-1 text-base leading-7 text-[var(--color-muted)]">
                {project.metadata.abstract}
              </p>
            </li>
          ))
        }
      </ol>
    </section>

    <p class="mt-12 text-sm text-[var(--color-muted)]">
      Source on
      <a
        class="text-[var(--color-link)] hover:underline hover:underline-offset-4"
        href="https://github.com/johnhooks/johnhooks.github.io">GitHub</a
      >.
    </p>
  </main>
</SiteLayout>
