---
import Image from "../components/Image.astro";
import {
  getHomeCurrent,
  getListedPosts,
  getListedProjects,
} from "../lib/astro/content";
import SiteLayout from "../layouts/SiteLayout.astro";

export const prerender = true;

const posts = getListedPosts();
const projects = getListedProjects();
const Current = getHomeCurrent();
---

<SiteLayout
  title="johnhooks.io"
  canonicalPath="/"
  breadcrumb={[{ label: "johnhooks.io" }]}
>
  <main class="site-shell page">
    <Image
      filename="computer_512.png"
      alt="Hand drawn crazy-eyed computer looking at me"
      darkBackground
    />

    <header class="page-header page-header--home">
      <p class="page-header__links">
        <a href="https://github.com/johnhooks">GitHub</a>
        <span class="page-header__separator">/</span>
        <a href="https://twitter.com/_johnhooks">Twitter</a>
      </p>
    </header>

    <section class="home-current prose" aria-label="Currently">
      <Current />
    </section>

    <section class="home-section">
      <h2 class="home-section__title">Posts</h2>

      <ol class="content-list">
        {
          posts.map((post) => (
            <li class="content-list__item">
              <h3 class="content-list__title">
                <a href={`/posts/${post.slug}`}>{post.metadata.title}</a>
              </h3>
              <p class="content-list__summary">{post.metadata.abstract}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="home-section">
      <h2 class="home-section__title">Projects</h2>

      <ol class="content-list">
        {
          projects.map((project) => (
            <li class="content-list__item">
              <h3 class="content-list__title">
                <a href={`/projects/${project.slug}`}>
                  {project.metadata.title}
                </a>
              </h3>
              <p class="content-list__summary">{project.metadata.abstract}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <p class="source-note">
      Source on <a href="https://github.com/johnhooks/johnhooks.github.io"
        >GitHub</a
      >.
    </p>
  </main>
</SiteLayout>
