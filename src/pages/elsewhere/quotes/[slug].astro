---
import QuoteNotFound from "../../../elsewhere/quotes/QuoteNotFound.astro";
import QuotePage from "../../../elsewhere/quotes/QuotePage.astro";
import { getQuotePageData } from "../../../elsewhere/quotes/quote-loader";

export const prerender = false;

const slug = Astro.params.slug;

if (!slug) {
  Astro.response.status = 404;
}

const { quote, summaries } = slug
  ? await getQuotePageData(slug)
  : { quote: undefined, summaries: [] };

if (!quote) {
  Astro.response.status = 404;
}
---

{quote ? <QuotePage quote={quote} quotes={summaries} /> : <QuoteNotFound />}
