---
import QuoteNotFound from "../../../elsewhere/quotes/QuoteNotFound.astro";
import QuotePage from "../../../elsewhere/quotes/QuotePage.astro";
import { getQuotes } from "../../../elsewhere/quotes/quote-loader";

export const prerender = false;

const slug = Astro.params.slug;

if (!slug) {
  Astro.response.status = 404;
}

const quotes = await getQuotes();
const quote = quotes.find((entry) => entry.slug === slug);

if (!quote) {
  Astro.response.status = 404;
}
---

{quote ? <QuotePage quote={quote} quotes={quotes} /> : <QuoteNotFound />}
