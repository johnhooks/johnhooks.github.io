---
type Props = {
  to: string;
  pathname: string;
  variant?: "elsewhere";
};

const { to, pathname, variant } = Astro.props;
const normalizePath = (path: string) =>
  path.length > 1 ? path.replace(/\/$/, "") : path;
const isActive = normalizePath(pathname) === normalizePath(to);
const className = [
  "site-nav__link",
  isActive ? "site-nav__link--active" : undefined,
  variant === "elsewhere" ? "site-nav__link--elsewhere" : undefined,
]
  .filter(Boolean)
  .join(" ");
---

<li>
  {
    isActive ? (
      <span class={className} aria-current="page">
        <slot />
      </span>
    ) : (
      <a href={to} class={className}>
        <slot />
      </a>
    )
  }
</li>
