---
type Props = {
  to: string;
  pathname: string;
};

const { to, pathname } = Astro.props;
const isActive = pathname === to;
const className = isActive
  ? "text-[var(--color-text)] underline decoration-[var(--color-link)] underline-offset-4"
  : "text-[var(--color-link)] hover:underline hover:underline-offset-4";
---

<li>
  <a href={to} class={className}>
    <slot />
  </a>
</li>
