---
import NavigationLink from "./NavigationLink.astro";

type Props = {
  pathname: string;
};

const { pathname } = Astro.props;
---

<div
  class="mx-auto max-w-[var(--measure)] px-[var(--gutter)] sm:px-[var(--gutter-wide)]"
>
  <header>
    <nav class="pt-6">
      <ul class="flex gap-5 text-base text-[var(--color-muted)]">
        <NavigationLink to="/" {pathname}>johnhooks.io</NavigationLink>
        <NavigationLink to="/about" {pathname}>about</NavigationLink>
      </ul>
    </nav>
  </header>
</div>
