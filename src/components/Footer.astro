---
import NavigationLink from "./NavigationLink.astro";

type Props = {
  pathname: string;
};

const { pathname } = Astro.props;
---

<footer class="mx-auto max-w-7xl px-4 sm:px-6">
  <nav class="flex justify-center pt-6">
    <ul class="flex px-3 text-sm font-medium text-zinc-800 dark:text-zinc-200">
      <NavigationLink to="/" {pathname}>home</NavigationLink>
      <NavigationLink to="/about" {pathname}>about</NavigationLink>
    </ul>
  </nav>
  <div class="pb-16 pt-10 text-center">
    <p class="text-sm text-zinc-400 dark:text-zinc-500">John Hooks © 2021 — 2022. All rights reserved.</p>
  </div>
</footer>
