---
import Image from "../components/Image.astro";
import { titleTransitionAnimation } from "../lib/astro/viewTransitions";
import SiteLayout from "./SiteLayout.astro";

type Props = {
  title: string;
  seoTitle?: string;
  subtitle: string;
  canonicalPath: string;
  cardFilename?: string;
  cardAlt?: string;
  titleTransitionName?: string;
  image?: {
    filename?: string;
    alt?: string;
  };
};

const {
  title,
  seoTitle,
  subtitle,
  canonicalPath,
  cardFilename,
  cardAlt,
  titleTransitionName,
  image,
} = Astro.props;

const titleClassName = titleTransitionName
  ? "page-header__title"
  : "page-header__title page-header__title--fade";
---

<SiteLayout
  title={`${seoTitle ?? title} / johnhooks.io`}
  description={subtitle}
  canonicalPath={canonicalPath}
  ogType="article"
  {cardFilename}
  {cardAlt}
>
  <main class="site-shell page">
    <article>
      {image?.filename && <Image filename={image.filename} alt={image.alt} />}

      <header class="page-header">
        {
          titleTransitionName ? (
            <h1
              class={titleClassName}
              transition:name={titleTransitionName}
              transition:animate={titleTransitionAnimation}
              data-title-transition-item
            >
              {title}
            </h1>
          ) : (
            <h1 class={titleClassName}>{title}</h1>
          )
        }
        <p class="page-header__subtitle">{subtitle}</p>
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
</SiteLayout>
