---
import Image from "../components/Image.astro";
import type { ImageAssetFilename } from "../lib/astro/images";
import SiteLayout from "./SiteLayout.astro";

type Props = {
  title: string;
  seoTitle?: string;
  subtitle: string;
  canonicalPath: string;
  cardFilename?: string;
  cardAlt?: string;
  image?: {
    filename: ImageAssetFilename;
    alt: string;
  };
  sourceUrl?: string;
  sourceLabel?: string;
};

const {
  title,
  seoTitle,
  subtitle,
  canonicalPath,
  cardFilename,
  cardAlt,
  image,
  sourceUrl,
  sourceLabel,
} = Astro.props;
const section = canonicalPath.startsWith("/posts/")
  ? "posts"
  : canonicalPath.startsWith("/projects/")
    ? "projects"
    : undefined;
const breadcrumb = [
  { label: "johnhooks.io", href: "/" },
  ...(section ? [{ label: section, href: `/${section}` }] : []),
  { label: title },
];
---

<SiteLayout
  title={`${seoTitle ?? title} / johnhooks.io`}
  description={subtitle}
  canonicalPath={canonicalPath}
  ogType="article"
  {cardFilename}
  {cardAlt}
  {breadcrumb}
>
  <main class="site-shell page">
    <article>
      {image?.filename && <Image filename={image.filename} alt={image.alt} />}

      <header class="page-header">
        <h1 class="page-header__title">{title}</h1>
        <p class="page-header__subtitle">{subtitle}</p>
        {
          sourceUrl && (
            <p class="page-header__links">
              <a href={sourceUrl}>{sourceLabel ?? sourceUrl}</a>
            </p>
          )
        }
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
</SiteLayout>
