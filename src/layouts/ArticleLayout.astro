---
import Image from "../components/Image.astro";
import SiteLayout from "./SiteLayout.astro";

type Props = {
  title: string;
  seoTitle?: string;
  subtitle: string;
  canonicalPath: string;
  cardFilename?: string;
  cardAlt?: string;
  image?: {
    filename?: string;
    alt?: string;
  };
};

const {
  title,
  seoTitle,
  subtitle,
  canonicalPath,
  cardFilename,
  cardAlt,
  image,
} = Astro.props;
---

<SiteLayout
  title={`${seoTitle ?? title} / johnhooks.io`}
  description={subtitle}
  canonicalPath={canonicalPath}
  ogType="article"
  {cardFilename}
  {cardAlt}
>
  <div class="text-[var(--color-text)]">
    <div
      class="mx-auto max-w-[var(--measure)] px-[var(--gutter)] pb-16 sm:px-[var(--gutter-wide)] sm:pb-12 lg:pb-16"
    >
      <article>
        {image?.filename && <Image filename={image.filename} alt={image.alt} />}

        <header class="mt-2 sm:mt-4">
          <h1
            class="text-3xl font-bold tracking-tight text-[var(--color-text)] sm:text-4xl"
          >
            {title}
          </h1>
          <p
            class="mt-4 text-base leading-7 text-[var(--color-muted)] sm:text-lg"
          >
            {subtitle}
          </p>
        </header>

        <div class="prose mt-10 lg:prose-lg">
          <slot />
        </div>
      </article>
    </div>
  </div>
</SiteLayout>
