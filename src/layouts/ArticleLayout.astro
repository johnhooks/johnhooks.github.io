---
import Image from "../components/Image.astro";
import SiteLayout from "./SiteLayout.astro";

type Props = {
  title: string;
  seoTitle?: string;
  subtitle: string;
  canonicalPath: string;
  cardFilename?: string;
  cardAlt?: string;
  image?: {
    filename?: string;
    alt?: string;
  };
};

const {
  title,
  seoTitle,
  subtitle,
  canonicalPath,
  cardFilename,
  cardAlt,
  image,
} = Astro.props;
---

<SiteLayout
  title={`${seoTitle ?? title} / johnhooks.io`}
  description={subtitle}
  canonicalPath={canonicalPath}
  ogType="article"
  {cardFilename}
  {cardAlt}
>
  <main class="site-shell page">
    <article>
      {image?.filename && <Image filename={image.filename} alt={image.alt} />}

      <header class="page-header">
        <h1 class="page-header__title">{title}</h1>
        <p class="page-header__subtitle">{subtitle}</p>
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
</SiteLayout>
