{
  "name": "johnhooks.io",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "homepage": "https://github.com/johnhooks/johnhooks.github.io#readme",
  "bugs": "https://github.com/johnhooks/johnhooks.github.io/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnhooks/johnhooks.github.io.git"
  },
  "author": {
    "name": "John Hooks",
    "url": "https://johnhooks.io"
  },
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "pnpm build && wrangler deploy --env production --var ENVIRONMENT:production --var SITE_URL:https://johnhooks.io",
    "deploy:staging": "pnpm build && wrangler deploy --env staging --var ENVIRONMENT:staging --var SITE_URL:https://website-staging.johnhooks.workers.dev",
    "check": "astro check",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.5.4",
    "@cloudflare/workers-types": "^4.20260523.1",
    "@eslint/js": "^10.0.1",
    "@shikijs/transformers": "^4.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.3.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "wrangler": "^4.94.0"
  }
}
